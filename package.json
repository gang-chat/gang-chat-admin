{
	"name": "gang-chat-admin",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "npm run dev:api",
		"dev:api": "tsx watch server/src/index.ts",
		"agent:worker": "tsx server/src/agent-worker/index.ts",
		"ai-admin-worker": "tsx server/src/ai-admin-worker/index.ts",
		"api": "tsx server/src/index.ts",
		"build": "npm run build:web && npm run build:api",
		"build:web": "vite build",
		"build:api": "esbuild server/src/index.ts --bundle --platform=node --format=esm --target=node22 --packages=external --outfile=server/dist/index.js",
		"start": "node server/dist/index.js",
		"start:api": "node server/dist/index.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:api": "tsc -p server/tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:api": "node --import tsx --test \"server/test/**/*.test.ts\"",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/geist": "^5.2.9",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.23.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24",
		"@types/ssh2": "^1.15.5",
		"clsx": "^2.1.1",
		"esbuild": "^0.28.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1077.0",
		"@aws-sdk/lib-storage": "^3.1077.0",
		"@earendil-works/pi-agent-core": "^0.80.3",
		"@earendil-works/pi-ai": "^0.80.3",
		"@fastify/cors": "^11.2.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/multipart": "^10.0.0",
		"@fastify/rate-limit": "^11.1.0",
		"@fastify/websocket": "^11.2.0",
		"@tanstack/table-core": "^8.21.3",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"bcryptjs": "^3.0.3",
		"bits-ui": "^2.18.1",
		"concurrently": "^10.0.3",
		"fastify": "^5.9.0",
		"jose": "^6.2.3",
		"mysql2": "^3.22.5",
		"nanoid": "^5.1.16",
		"node-pty": "^1.1.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"ssh2": "^1.17.0",
		"sveltekit-superforms": "^2.30.1",
		"ws": "^8.21.0",
		"zod": "^4.4.3"
	}
}
